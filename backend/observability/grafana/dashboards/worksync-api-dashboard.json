{
  "title": "WorkSync API",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Rate",
      "targets": [
        {
          "expr": "sum(rate(worksync_http_requests_total[1m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "p95 Latency (ms)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(worksync_http_request_duration_seconds_bucket[5m])) by (le, route)) * 1000",
          "legendFormat": "{{route}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "5xx Errors / sec",
      "targets": [
        {
          "expr": "sum(rate(worksync_http_requests_total{status_code=~\"5..\"}[1m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "type": "timeseries",
      "title": "CPU and Memory (Node)",
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total[1m])",
          "legendFormat": "cpu"
        },
        {
          "expr": "process_resident_memory_bytes",
          "legendFormat": "memory"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ]
}
